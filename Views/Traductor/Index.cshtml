@{
    ViewData["Title"] = "Traductor AR-SQL";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white text-center rounded-top">
                    <h2 class="mb-0">
                        <i class="bi bi-translate"></i> Traductor AR ⇄ SQL
                    </h2>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Traducir" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Modo:</label>
                            <select name="modo" class="form-select">
                                <option value="AR2SQL" selected>AR → SQL</option>
                                <option value="SQL2AR">SQL → AR</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Texto:</label>
                            <textarea name="texto" rows="5" class="form-control">@ViewBag.Texto</textarea>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-arrow-right-circle"></i> Traducir
                            </button>
                        </div>
                    </form>

                    @if (ViewBag.Resultado != null)
                    {
                        <div class="mt-4">
                            <h4>Resultado:</h4>
                            <pre class="p-3 bg-light border rounded">@ViewBag.Resultado</pre>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Bootstrap Icons (si no están en tu layout) -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<!-- Estilos adicionales opcionales -->
<style>
    body {
        background: linear-gradient(135deg, #f8f9fa, #e3f2fd);
    }

    .card {
        border-radius: 1rem;
    }

    .btn-primary {
        transition: all 0.3s ease-in-out;
    }

        .btn-primary:hover {
            background-color: #0a58ca;
            transform: scale(1.02);
        }
</style>




