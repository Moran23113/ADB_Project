@{
    ViewData["Title"] = "Modelo Relacional (Mermaid erDiagram)";
    var nombreBD = (string)ViewBag.NombreBD;
    var mermaidRel = (string)ViewBag.MermaidRel;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3>Modelo Relacional de @nombreBD</h3>
    <div class="d-flex gap-2">
        <a class="btn btn-secondary" asp-controller="DiagramaEr" asp-action="Subir">Volver</a>
        <form asp-controller="DiagramaEr" asp-action="EliminarBase" method="post"
              onsubmit="return confirm('¿Eliminar la base restaurada?');" class="d-inline">
            <input type="hidden" name="nombreBD" value="@nombreBD" />
            <button class="btn btn-outline-danger">Eliminar BD</button>
        </form>
    </div>
</div>

@if (TempData["msg"] != null)
{
    <div class="alert alert-info">@TempData["msg"]</div>
}

<script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
<script>
    mermaid.initialize({
      startOnLoad: true,
      securityLevel: 'loose',
      maxTextSize: 10000000
    });
</script>

<pre class="mermaid">
@mermaidRel
</pre>

<details class="mt-3">
    <summary>Ver código Mermaid (depuración)</summary>
    <textarea style="width:100%;height:260px" readonly>
@Html.Raw(System.Net.WebUtility.HtmlEncode(mermaidRel))
  </textarea>
</details>

<form asp-action="ExportarSql" method="post" class="mt-3">
    <input type="hidden" name="nombreBD" value="@nombreBD" />
    <button class="btn btn-success">Exportar SQL</button>
</form>
