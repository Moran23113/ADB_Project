@{
    ViewData["Title"] = "Generar modelo relacional desde .bak";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white text-center rounded-top">
                    <h2 class="mb-0">
                        <i class="bi bi-table"></i> @ViewData["Title"]
                    </h2>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Subir" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Selecciona un archivo .bak</label>
                            <input type="file" id="archivoRespaldo" name="archivoRespaldo" class="form-control" accept=".bak" />
                            <div class="form-text text-muted">
                                Solo se permiten archivos con extensión <code>.bak</code>.
                            </div>
                            <div id="filePreview" class="file-preview"></div>
                        </div>

                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg">
                                <i class="bi bi-cloud-upload"></i> Generar modelo relacional
                            </button>
                        </div>
                    </form>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mt-4 mb-2">
                            <h6><i class="bi bi-exclamation-triangle"></i> Errores encontrados:</h6>
                            <ul class="mb-0">
                                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@e.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (TempData["msg"] != null)
                    {
                        <div class="alert alert-info mt-3">
                            <i class="bi bi-info-circle"></i> @TempData["msg"]
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #e3f2fd, #ffffff);
    }
    .card {
        border-radius: 1rem;
    }
    .btn-primary {
        transition: all 0.3s ease-in-out;
    }
    .btn-primary:hover {
        background-color: #0a58ca;
        transform: scale(1.02);
    }
    .file-preview {
        margin-top: 0.5rem;
        font-size: 0.9rem;
        color: #0d6efd;
        font-weight: 500;
    }
</style>

<script>
    const archivoInput = document.getElementById("archivoRespaldo");
    const filePreview = document.getElementById("filePreview");

    if (archivoInput) {
        archivoInput.addEventListener("change", () => {
            const file = archivoInput.files[0];
            if (file) {
                filePreview.textContent = `Archivo seleccionado: ${file.name}`;
            } else {
                filePreview.textContent = "";
            }
        });
    }
</script>

