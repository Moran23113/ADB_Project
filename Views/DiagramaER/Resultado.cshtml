@using System
@{
    ViewData["Title"] = "Diagrama estilo Chen + EER";
    var mermaid = (string)ViewBag.Mermaid;
    var nombreBD = (string)ViewBag.NombreBD;
    var mermaidEer = ViewBag.MermaidEER as string;
    var ambiguas = ViewBag.JerarquiasAmbiguas as List<JerarquiaEer>;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3>Modelo (Chen) de @nombreBD</h3>
    <form asp-action="EliminarBase" method="post" onsubmit="return confirm('¿Eliminar la base restaurada?');">
        <input type="hidden" name="nombreBD" value="@nombreBD" />
        <button class="btn btn-outline-danger">Eliminar BD</button>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
<script>
    mermaid.initialize({
      startOnLoad: true,
      maxTextSize: 10000000,
      securityLevel: 'loose'
    });
</script>

@if (TempData["msg"] != null)
{
    <div class="alert alert-info">@TempData["msg"]</div>
}

<h4 class="mt-2">Diagrama ER (Chen)</h4>
<pre class="mermaid">
@mermaid
</pre>

@if (!string.IsNullOrWhiteSpace(mermaidEer))
{
    <h4 class="mt-4">Jerarquías y Especializaciones (EER)</h4>
    <pre class="mermaid">
@mermaidEer
    </pre>
}

@if (ambiguas != null && ambiguas.Any())
{
    <h4 class="mt-4">Resolver ambigüedades EER</h4>
    <p class="text-muted">Selecciona Disyunción (Exclusiva/Solapada) y Totalidad (Total/Parcial) para cada jerarquía.</p>

    <form asp-action="GuardarChoices" method="post">
        <!-- Enviar también la BD restaurada para guardar las elecciones ahí -->
        <input type="hidden" name="NombreBD" value="@nombreBD" />

        @foreach (var j in ambiguas)
        {
            var subsCsv = string.Join(",", j.Subtipos.OrderBy(x => x, StringComparer.OrdinalIgnoreCase));
            <div class="border p-3 mb-3">
                <div><b>Supertipo:</b> @j.Supertipo</div>
                <div><b>Subtipos:</b> @string.Join(", ", j.Subtipos)</div>
                @if (!string.IsNullOrWhiteSpace(j.Evidencia))
                {
                    <div class="text-muted"><small>@j.Evidencia</small></div>
                }

                <input type="hidden" name="SubtypesCsv[@j.Supertipo]" value="@subsCsv" />

                <div class="row mt-2">
                    <div class="col-md-6">
                        <label class="form-label">Disyunción:</label>
                        <select name="Disyuncion[@j.Supertipo]" class="form-select">
                            <option value="Exclusive" selected="selected">Exclusiva (disyunta)</option>
                            <option value="Overlapping">Solapada (overlapping)</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Totalidad:</label>
                        <select name="Totalidad[@j.Supertipo]" class="form-select">
                            <option value="Total">Total</option>
                            <option value="Partial" selected="selected">Parcial</option>
                        </select>
                    </div>
                </div>
            </div>
        }

        <button type="submit" class="btn btn-success">Guardar elecciones</button>
    </form>
}
else
{
    <div class="alert alert-secondary mt-4">No hay ambigüedades EER por resolver.</div>
}

<details class="mt-3">
    <summary>Ver código Mermaid (depuración)</summary>
    <textarea style="width:100%;height:260px" readonly>
@Html.Raw(System.Net.WebUtility.HtmlEncode(mermaid))

@(string.IsNullOrWhiteSpace(mermaidEer) ? "" :
    "\n\n--- EER ---\n" + System.Net.WebUtility.HtmlEncode(mermaidEer))
  </textarea>
</details>
