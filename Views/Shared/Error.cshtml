@model ModeloVistaError
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Ocurrió un error.</h1>

@if (Model.MostrarRequestId)
{
    <p><strong>Id de solicitud:</strong> <code>@Model.RequestId</code></p>
}

<p>En entorno <strong>Development</strong> se mostrarán detalles adicionales del error.</p>
<p>En producción los detalles se ocultan para proteger información sensible.</p>
